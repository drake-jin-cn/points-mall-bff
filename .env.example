# ============================================================
# points-mall-bff — Environment Variables Reference
# Copy this file to .env.dev / .env.test / .env.prod and fill in real values.
# NEVER commit files with real secrets to Git.
# ============================================================

# ── Application ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── JWT (Required) ──────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Required in production
REDIS_PASSWORD=

# ── Internal Service URLs ────────────────────────────────────
CORE_SERVICE_URL=http://localhost:8080
SHOP_SERVICE_URL=http://localhost:8081
MESSAGE_SERVICE_URL=http://localhost:8082
DATA_SERVICE_URL=http://localhost:8083
THIRDPARTY_SERVICE_URL=http://localhost:8084

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672

# ── CORS ────────────────────────────────────────────────────
# Comma-separated allowed origins; restrict in production
CORS_ORIGINS=http://localhost:3003
